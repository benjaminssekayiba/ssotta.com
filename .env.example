# Required for production SEO files (canonical URLs, sitemap.xml, robots.txt).
# No trailing slash.
VITE_SITE_URL=https://www.yourdomain.com

# Optional: Google Analytics 4 measurement ID (example: G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=

# Optional: Supabase central booking storage.
# Create a free project at https://supabase.com, run supabase/schema.sql, then paste values here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
